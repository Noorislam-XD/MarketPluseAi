# Crypto — CoinGecko needs no key
# US + Indian indices — Yahoo Finance needs no key

# Economic calendar — https://finnhub.io/register (free tier)
FINNHUB_API_KEY=

# Movers, Forex (USD/INR, EUR/USD) & Commodities (Gold, Silver, Crude Oil) —
# https://www.alphavantage.co/support/#api-key (free, 25 req/day)
ALPHAVANTAGE_API_KEY=

# News — https://newsapi.org/register (free tier)
NEWS_API_KEY=

# AI summary + risks — https://openrouter.ai/keys (use a free-tier model)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Telegram — message @BotFather to create a bot, then get your chat_id
# via https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set automatically by the GitHub Actions workflow per schedule; only needed
# locally if you want to test a specific brief label.
BRIEF_TYPE=
