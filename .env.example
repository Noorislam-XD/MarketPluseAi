# Crypto — CoinGecko needs no key
# Fear & Greed — alternative.me needs no key

# Stocks — https://finnhub.io/register (free tier)
FINNHUB_API_KEY=

# Movers — https://www.alphavantage.co/support/#api-key (free, 25 req/day)
ALPHAVANTAGE_API_KEY=

# News — https://newsapi.org/register (free tier)
NEWS_API_KEY=

# AI — https://openrouter.ai/keys (use a free-tier model)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Telegram — message @BotFather to create a bot, then get your chat_id
# via https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
